# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare file types
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.wasm binary

# Git LFS (if used for large assets)
# *.wav filter=lfs diff=lfs merge=lfs -text

# Documentation
*.rst text eol=lf

# Notebooks - treat as binary to avoid merge issues (or use nbstripout)
*.ipynb binary
